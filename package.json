{
  "name": "agentsynclayer",
  "version": "0.5.0",
  "description": "Redis-backed pub/sub messaging for coordinating multiple AI agent sessions",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test test/unit/",
    "test:integration": "bun test test/integration/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ bus-monitor.ts smoke-test.ts",
    "lint:fix": "biome check --write --unsafe src/ bus-monitor.ts smoke-test.ts",
    "format": "biome format --write src/ bus-monitor.ts smoke-test.ts",
    "check": "tsc --noEmit && biome check src/ bus-monitor.ts smoke-test.ts"
  },
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@opencode-ai/plugin": "^1.4.0",
    "@types/bun": "^1.0.0",
    "@types/node": "^20.11.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
